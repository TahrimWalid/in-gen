# LLM Provider Configuration
# Copy this file to .env.local and fill in your values.

# Base URL of an OpenAI-compatible chat completions endpoint.
# Claude (Anthropic): https://api.anthropic.com
# Local Ollama:       http://localhost:11434
# Self-hosted vLLM:   http://your-server:8000
LLM_BASE_URL=

# API key for the provider above. Leave empty for unauthenticated local endpoints.
LLM_API_KEY=

# Model identifier to pass to the completions endpoint.
# Claude example:  claude-sonnet-4-6
# Ollama example:  qwen3:6b
# OpenAI example:  gpt-4o
LLM_MODEL=
